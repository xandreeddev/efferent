{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "types": ["bun"],
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@xandreed/engine": ["packages/engine/src/index.ts"],
      "@xandreed/engine/*": ["packages/engine/src/*"],
      "@xandreed/providers": ["packages/providers/src/index.ts"],
      "@xandreed/providers/*": ["packages/providers/src/*"],
      "@xandreed/surface": ["packages/surface/src/index.ts"],
      "@xandreed/surface/*": ["packages/surface/src/*"],
      "@xandreed/canvas": ["packages/canvas/src/index.ts"],
      "@xandreed/canvas/*": ["packages/canvas/src/*"],
      "@xandreed/scenarios": ["packages/scenarios/src/index.ts"],
      "@xandreed/scenarios/*": ["packages/scenarios/src/*"],
      "@xandreed/foundry": ["packages/foundry/src/index.ts"],
      "@xandreed/foundry/*": ["packages/foundry/src/*"],
      "@xandreed/smith": ["packages/smith/src/index.ts"],
      "@xandreed/smith/*": ["packages/smith/src/*"],
      "@xandreed/math": ["packages/math/src/index.ts"],
      "@xandreed/math/*": ["packages/math/src/*"],
      "@xandreed/social": ["packages/social/src/index.ts"],
      "@xandreed/social/*": ["packages/social/src/*"],
      "@xandreed/ui-agent": ["packages/ui-agent/src/index.ts"],
      "@xandreed/ui-agent/profiles/streaming-ui-v1": ["packages/ui-agent/profiles/streaming-ui-v1.json"],
      "@xandreed/ui-agent/*": ["packages/ui-agent/src/*"]
    }
  }
}

{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM"],
    "types": ["bun"],
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "allowArbitraryExtensions": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@xandreed/sdk-core": ["packages/sdk-core/src/index.ts"],
      "@xandreed/sdk-core/*": ["packages/sdk-core/src/*"],
      "@xandreed/application": ["packages/application/src/index.ts"],
      "@xandreed/application/*": ["packages/application/src/*"],
      "@xandreed/sdk-adapters": ["packages/sdk-adapters/src/index.ts"],
      "@xandreed/sdk-adapters/*": ["packages/sdk-adapters/src/*"],
      "@xandreed/engine": ["packages/engine/src/index.ts"],
      "@xandreed/engine/*": ["packages/engine/src/*"],
      "@xandreed/foundry": ["packages/foundry/src/index.ts"],
      "@xandreed/foundry/*": ["packages/foundry/src/*"],
      "@xandreed/smith": ["packages/smith/src/index.ts"],
      "@xandreed/smith/*": ["packages/smith/src/*"],
      "@xandreed/math": ["packages/math/src/index.ts"],
      "@xandreed/math/*": ["packages/math/src/*"],
      "@xandreed/web": ["packages/web/src/index.ts"],
      "@xandreed/web/*": ["packages/web/src/*"],
      "efferent/*": ["packages/cli/src/*"]
    }
  }
}

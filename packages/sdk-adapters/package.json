{
  "name": "@xandreed/sdk-adapters",
  "version": "0.4.1",
  "type": "module",
  "description": "efferent SDK — Layer implementations of the sdk-core ports: multi-provider LLM router, auth, conversation/context stores (SQLite + Postgres), settings, fs/shell/http. Side effects live here.",
  "license": "MIT",
  "keywords": [
    "effect",
    "effect-ts",
    "ai-agent",
    "sdk",
    "llm",
    "adapters"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xandreeddev/efferent.git",
    "directory": "packages/sdk-adapters"
  },
  "homepage": "https://github.com/xandreeddev/efferent#readme",
  "bugs": {
    "url": "https://github.com/xandreeddev/efferent/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json"
  },
  "dependencies": {
    "@xandreed/sdk-core": "workspace:*",
    "@effect/ai": "^0.35.0",
    "@effect/ai-anthropic": "^0.25.0",
    "@effect/ai-google": "^0.14.0",
    "@effect/ai-openai": "^0.39.2",
    "@effect/experimental": "^0.60.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.1",
    "@effect/sql": "^0.51.1",
    "@effect/sql-pg": "^0.52.1",
    "@effect/sql-sqlite-bun": "^0.52.0",
    "@opentelemetry/api": "^1.9.1",
    "effect": "^3.21.4"
  }
}

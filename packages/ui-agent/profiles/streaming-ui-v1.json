{
  "profile": "streaming-ui-v1",
  "version": "10.1.0",
  "schemaVersion": "2.1.0",
  "recipeSetVersion": "2.0.0",
  "protocol": "native-tools",
  "prompts": {
    "planner": "10.0.0",
    "composer": "11.0.0",
    "repair": "8.0.0"
  },
  "planner": {
    "model": "openai-codex:gpt-5.6-luna",
    "effort": "medium",
    "timeoutMs": 15000,
    "maxOutputTokens": 2400,
    "maxSteps": 2
  },
  "composer": {
    "model": "openai-codex:gpt-5.6-luna",
    "effort": "medium",
    "timeoutMs": 20000,
    "maxOutputTokens": 5000,
    "maxSteps": 5,
    "workers": 2
  },
  "repair": {
    "model": "openai-codex:gpt-5.6-luna",
    "effort": "medium",
    "timeoutMs": 8000,
    "maxOutputTokens": 1800,
    "maxSteps": 2,
    "maxAttempts": 1
  },
  "fallback": {
    "policy": "profile",
    "model": "opencode:glm-5.2"
  }
}

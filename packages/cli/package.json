{
  "name": "efferent",
  "version": "0.6.0",
  "description": "efferent — an agent runtime on Effect.ts + Bun. One CLI to run agents: an interactive TUI, headless (print/json/rpc), or a persistent per-workspace daemon that thin clients attach to. Multi-provider (Anthropic/OpenAI/Gemini), persistent sub-agent context tree, cache-safe context compression, zero-config SQLite history. No React.",
  "license": "MIT",
  "author": "Xand Reed <xandreed@proton.me>",
  "type": "module",
  "bin": {
    "efferent": "dist/efferent.js",
    "eff": "dist/efferent.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xandreeddev/efferent.git"
  },
  "homepage": "https://github.com/xandreeddev/efferent#readme",
  "bugs": {
    "url": "https://github.com/xandreeddev/efferent/issues"
  },
  "keywords": [
    "agent-runtime",
    "agent",
    "ai-agent",
    "daemon",
    "cli",
    "tui",
    "effect",
    "bun",
    "llm",
    "anthropic",
    "openai",
    "gemini"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run ../../scripts/build.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@opentui/core": "0.3.1",
    "web-tree-sitter": "0.25.10"
  },
  "devDependencies": {
    "@xandreed/sdk-adapters": "workspace:*",
    "@xandreed/sdk-core": "workspace:*",
    "@effect/ai": "^0.35.0",
    "@effect/cli": "^0.75.1",
    "@effect/platform": "^0.96.1",
    "@effect/platform-bun": "^0.89.0",
    "@opentui/solid": "0.3.1",
    "effect": "^3.21.4",
    "solid-js": "1.9.12"
  }
}

    "e": "dist/efferent.js",
    "code": "dist/code.js"
  },
  "files": ["dist"],
  "engines": {
    "bun": ">=1.2.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xandreeddev/efferent.git"
  },
  "homepage": "https://github.com/xandreeddev/efferent#readme",
  "bugs": {
    "url": "https://github.com/xandreeddev/efferent/issues"
  },
  "keywords": [
    "coding-agent",
    "agent",
    "cli",
    "tui",
    "effect",
    "bun",
    "llm",
    "anthropic",
    "openai",
    "gemini"
  ],
  "publishConfig": {

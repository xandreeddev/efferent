{
  "name": "@xandreed/evals",
  "version": "0.2.2",
  "type": "module",
  "description": "efferent SDK — a minimal, Effect-native eval library: the data → task → scorers shape as Effects, so a task can be the real agent loop and a scorer can call an LLM. Trace-first reporting.",
  "license": "MIT",
  "keywords": [
    "effect",
    "effect-ts",
    "ai-agent",
    "evals",
    "llm",
    "llm-as-judge"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xandreeddev/efferent.git",
    "directory": "packages/evals"
  },
  "homepage": "https://github.com/xandreeddev/efferent#readme",
  "bugs": {
    "url": "https://github.com/xandreeddev/efferent/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json"
  },
  "dependencies": {
    "@xandreed/sdk-adapters": "workspace:*",
    "@xandreed/sdk-core": "workspace:*",
    "@effect/ai": "^0.35.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform-bun": "^0.89.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "effect": "^3.21.4"
  }
}

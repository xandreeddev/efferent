# Get a key at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Override default model. Examples: gemini-3.5-flash, gemini-2.5-flash
EFFERENT_MODEL=gemini-3.5-flash

# Server
PORT=3000

# Postgres. Local default points at the Docker compose service.
# For deployed environments (Neon / Supabase / Railway / etc.), set this
# to the provider's URL — same library, same schema, same migrations.
EFFERENT_DB_URL=postgres://agent:agent@localhost:5434/agent

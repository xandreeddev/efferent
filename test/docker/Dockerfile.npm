# Clean-room test of the PUBLISHED `efferent@0.2.0` from npm — no mounted configs.
# Installs exactly as a new user would, plus tmux so the interactive first-run
# (onboarding + :login) can be driven and captured. No ~/.efferent is mounted;
# credentials are entered through the in-app :login flow, isolated from the host.
FROM node:24-slim
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates tmux procps \
 && rm -rf /var/lib/apt/lists/* \
 && npm i -g bun
ARG SPEC=efferent@0.2.0
RUN npm i -g "${SPEC}"
RUN mkdir -p /work && printf '# scratch project\n' > /work/README.md
WORKDIR /work
CMD ["sleep", "infinity"]

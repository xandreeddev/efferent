{
  "uid": "efferent-agent",
  "title": "efferent — agent metrics",
  "tags": ["efferent"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "LLM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "timeseries",
      "title": "Tokens by role/type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "stacking": { "mode": "normal" } } } },
      "targets": [
        { "expr": "sum by (role, type) (gen_ai_tokens_total)", "legendFormat": "{{role}}/{{type}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM calls by role/model",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "targets": [
        { "expr": "sum by (role, model) (gen_ai_calls_total)", "legendFormat": "{{role}} {{model}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Turn latency p95 (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_turn_latency_ms_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Tools & approvals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "timeseries",
      "title": "Tool calls by tool/ok",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        { "expr": "sum by (tool, ok) (agent_tool_calls_total)", "legendFormat": "{{tool}} ok={{ok}}", "refId": "A" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Agent turns",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        { "expr": "sum (agent_turns_total)", "legendFormat": "turns", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Auto-approval verdicts",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        { "expr": "sum by (verdict) (approval_verdicts_total)", "legendFormat": "{{verdict}}", "refId": "A" }
      ]
    },
    {
      "type": "row",
      "title": "Evals",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "timeseries",
      "title": "Eval mean score by suite",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": { "defaults": { "min": 0, "max": 1 } },
      "targets": [
        {
          "expr": "sum by (suite) (eval_score_sum) / sum by (suite) (eval_score_count)",
          "legendFormat": "{{suite}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "bargauge",
      "title": "Eval cases (passed/failed)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "targets": [
        { "expr": "sum by (suite, passed) (eval_cases_total)", "legendFormat": "{{suite}} passed={{passed}}", "refId": "A" }
      ]
    }
  ]
}

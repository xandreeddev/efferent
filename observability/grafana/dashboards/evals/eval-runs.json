{
  "uid": "efferent-evals",
  "title": "efferent — eval runs",
  "tags": ["efferent", "evals"],
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "links": [
    { "title": "Fleet health (production)", "type": "link", "url": "/d/efferent-fleet/efferent-fleet", "icon": "external link" }
  ],
  "templating": {
    "list": [
      {
        "name": "run",
        "label": "run id(s)",
        "type": "query",
        "datasource": { "type": "tempo", "uid": "tempo" },
        "query": { "type": "tagValues", "tag": "resource.eval.run_id" },
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "sort": 5,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "suite",
        "label": "suite",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(eval_score_count{job=\"efferent-evals\"}, suite)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "scorer",
        "label": "scorer / judge",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(eval_score_count{job=\"efferent-evals\"}, scorer)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "How to read this",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Eval telemetry only (`job=\"efferent-evals\"`), disjoint from real sessions. **Pick `run id(s)`** (top bar — populated from the `eval.run_id` of runs that reached the stack; `bun run eval` prints a deep link that pre-selects the just-finished run) to scope the per-run tables to those run(s). The **judge/scorer** panels break each suite's mean into its individual scorers (the LLM judge + deterministic checks); narrow with `suite` / `scorer`. Per-case judge sub-scores live on each `eval.case` span — click a row's **Trace ID** to open the case (its `eval.scorer:*` children + `eval.score.*` attrs). Scores are 0–1; cost reuses the same catalogue pricing a real session uses."
      }
    },

    { "type": "row", "title": "Scores & judges", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 } },
    {
      "type": "timeseries",
      "title": "Mean score by suite",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum by (suite) (eval_score_sum{job=\"efferent-evals\", suite=~\"$suite\"}) / clamp_min(sum by (suite) (eval_score_count{job=\"efferent-evals\", suite=~\"$suite\"}), 1)", "legendFormat": "{{suite}}", "refId": "A" }
      ]
    },
    {
      "type": "bargauge",
      "title": "Score by scorer / judge (suite · scorer)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 9, "x": 8, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.85 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        { "expr": "sum by (suite, scorer) (eval_score_sum{job=\"efferent-evals\", suite=~\"$suite\", scorer=~\"$scorer\"}) / clamp_min(sum by (suite, scorer) (eval_score_count{job=\"efferent-evals\", suite=~\"$suite\", scorer=~\"$scorer\"}), 1)", "legendFormat": "{{suite}} · {{scorer}}", "refId": "A" }
      ]
    },
    {
      "type": "bargauge",
      "title": "Pass rate by suite",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 7, "x": 17, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.9 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        { "expr": "sum by (suite) (eval_cases_total{job=\"efferent-evals\", passed=\"true\", suite=~\"$suite\"}) / clamp_min(sum by (suite) (eval_cases_total{job=\"efferent-evals\", suite=~\"$suite\"}), 1)", "legendFormat": "{{suite}}", "refId": "A" }
      ]
    },

    { "type": "row", "title": "Selected run(s): $run", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 } },
    {
      "type": "table",
      "title": "Cases in the selected run(s) — click a Trace ID for the case (judge sub-scores)",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 14 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"efferent-evals\" && name = \"eval.case\" && resource.eval.run_id =~ \"$run\" } | select(resource.eval.run_id, span.eval.suite, span.eval.case, span.eval.mean, span.eval.ok)",
          "tableType": "spans",
          "limit": 500,
          "spss": 20
        }
      ],
      "options": { "showHeader": true }
    },

    { "type": "row", "title": "Runs & spend", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 } },
    {
      "type": "table",
      "title": "Eval runs (configs) — copy a run id into the selector, or click a Trace ID for the run waterfall",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 27 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"efferent-evals\" && name = \"eval.run\" } | select(resource.eval.run_id, span.config.name, span.config.main, span.config.fast)",
          "tableType": "spans",
          "limit": 100,
          "spss": 1
        }
      ],
      "options": { "showHeader": true }
    },
    {
      "type": "stat",
      "title": "Eval spend (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 27 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [ { "expr": "sum(increase(gen_ai_cost_usd_total{job=\"efferent-evals\"}[$__range]))", "legendFormat": "spend", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Cases run (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 31 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [ { "expr": "sum(increase(eval_cases_total{job=\"efferent-evals\", suite=~\"$suite\"}[$__range]))", "legendFormat": "cases", "refId": "A" } ]
    }
  ]
}

{
  "uid": "efferent-evals",
  "title": "efferent — eval runs",
  "tags": ["efferent", "evals"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "links": [
    { "title": "Fleet health (production)", "type": "link", "url": "/d/efferent-fleet/efferent-fleet", "icon": "external link" }
  ],
  "templating": {
    "list": [
      {
        "name": "suite",
        "label": "suite",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(eval_score_count{job=\"efferent-evals\"}, suite)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "run",
        "label": "run id (trace filter)",
        "type": "textbox",
        "query": "",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "panels": [
    {
      "type": "text",
      "title": "How to read this",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Eval telemetry only (`service.name = efferent-evals` → `job=\"efferent-evals\"`), disjoint from real sessions. `bun run eval` prints a deep link with a `var-run` for the just-finished run; paste a run id into **run id** to scope the case-trace table. Scores are 0–1; cost reuses the same catalogue pricing a real session uses."
      }
    },
    {
      "type": "timeseries",
      "title": "Mean score by suite",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [
        { "expr": "sum by (suite) (eval_score_sum{job=\"efferent-evals\", suite=~\"$suite\"}) / clamp_min(sum by (suite) (eval_score_count{job=\"efferent-evals\", suite=~\"$suite\"}), 1)", "legendFormat": "{{suite}}", "refId": "A" }
      ]
    },
    {
      "type": "bargauge",
      "title": "Pass rate by suite",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.6 }, { "color": "green", "value": 0.9 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [
        { "expr": "sum by (suite) (eval_cases_total{job=\"efferent-evals\", passed=\"true\", suite=~\"$suite\"}) / clamp_min(sum by (suite) (eval_cases_total{job=\"efferent-evals\", suite=~\"$suite\"}), 1)", "legendFormat": "{{suite}}", "refId": "A" }
      ]
    },
    {
      "type": "stat",
      "title": "Eval spend (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4, "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [ { "expr": "sum(increase(gen_ai_cost_usd_total{job=\"efferent-evals\"}[$__range]))", "legendFormat": "spend", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Tokens by role (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [ { "expr": "sum by (role) (increase(gen_ai_tokens_total{job=\"efferent-evals\"}[$__range]))", "legendFormat": "{{role}}", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Cases run (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 11 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [ { "expr": "sum(increase(eval_cases_total{job=\"efferent-evals\", suite=~\"$suite\"}[$__range]))", "legendFormat": "cases", "refId": "A" } ]
    },
    {
      "type": "table",
      "title": "Eval runs (configs) — click a Trace ID for the run waterfall",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"efferent-evals\" && name = \"eval.run\" } | select(resource.eval.run_id, span.config.name, span.config.main, span.config.fast)",
          "tableType": "spans",
          "limit": 100,
          "spss": 1
        }
      ],
      "options": { "showHeader": true }
    },
    {
      "type": "table",
      "title": "Cases for run $run — click a Trace ID for the case waterfall",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 25 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"efferent-evals\" && name = \"eval.case\" && resource.eval.run_id =~ \"$run\" } | select(span.eval.suite, span.eval.case, span.eval.mean, span.eval.ok)",
          "tableType": "spans",
          "limit": 200,
          "spss": 10
        }
      ],
      "options": { "showHeader": true }
    }
  ]
}

{
  "uid": "efferent-conversations",
  "title": "efferent — conversations",
  "tags": ["efferent", "production"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "links": [
    { "title": "Fleet health", "type": "link", "url": "/d/efferent-fleet/efferent-fleet", "icon": "external link" },
    { "title": "Conversation drill-down", "type": "link", "url": "/d/efferent-conversation/efferent-conversation", "icon": "external link" }
  ],
  "templating": { "list": [] },
  "panels": [
    {
      "type": "text",
      "title": "How to read this",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "Each row is **one user message** (its `agent.run` trace) — it appears once the run **completes** (the root span exports on finish; child spans show mid-run in the waterfall). Click a row's **span** to open the full execution focused on that message's `agent.run` span (`agent.run → agent.turn → llm.generate / agent.tool / agent.subagent`). Click a **conversation id** to drill into just that conversation, or use the **Conversation drill-down** link (top-right). Filtered to `service.name = efferent` (real sessions; evals live in their own folder)."
      }
    },
    {
      "type": "table",
      "title": "Recent messages (newest first) — click a conversation id to drill in",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"efferent\" && name =~ \"agent\\.run.*\" } | select(span.agent.conversation_id, span.agent.prompt, span.agent.model)",
          "tableType": "spans",
          "limit": 200,
          "spss": 1
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "traceService": true,
              "traceName": true,
              "name": true,
              "service.name": true,
              "duration": true
            },
            "indexByName": {
              "agent.prompt": 0,
              "time": 1,
              "agent.model": 2,
              "agent.conversation_id": 3,
              "spanID": 4
            },
            "renameByName": {
              "agent.prompt": "user message",
              "time": "when",
              "agent.model": "model",
              "agent.conversation_id": "conversation",
              "spanID": "span"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "agent.prompt" },
            "properties": [{ "id": "custom.width", "value": 560 }]
          },
          {
            "matcher": { "id": "byName", "options": "agent.conversation_id" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "Drill into this conversation",
                    "url": "/d/efferent-conversation/efferent-conversation?var-conversation=${__value.raw}",
                    "targetBlank": false
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "spanID" },
            "properties": [{ "id": "custom.width", "value": 150 }]
          }
        ]
      },
      "options": { "showHeader": true }
    }
  ]
}

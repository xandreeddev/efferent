{
  "uid": "efferent-fleet",
  "title": "efferent — fleet health",
  "tags": ["efferent", "production"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-3h", "to": "now" },
  "links": [
    { "title": "Conversations", "type": "link", "url": "/d/efferent-conversations/efferent-conversations", "icon": "external link" },
    { "title": "Eval runs", "type": "link", "url": "/d/efferent-evals/efferent-evals", "icon": "external link" }
  ],
  "templating": {
    "list": [
      {
        "name": "role",
        "label": "role",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(gen_ai_calls_total{job=\"efferent\"}, role)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "model",
        "label": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(gen_ai_calls_total{job=\"efferent\"}, model)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "Overview (selected range)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "type": "stat",
      "title": "Spend",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3, "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [ { "expr": "sum(increase(gen_ai_cost_usd_total{job=\"efferent\"}[$__range]))", "legendFormat": "spend", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Turn error rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.02 }, { "color": "red", "value": 0.1 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [ { "expr": "sum(rate(agent_errors_total{job=\"efferent\", kind=\"turn\"}[$__range])) / clamp_min(sum(rate(agent_turns_total{job=\"efferent\"}[$__range])), 1)", "legendFormat": "err%", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Cache hit rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "green", "value": 0.6 } ] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [ { "expr": "sum(rate(gen_ai_tokens_total{job=\"efferent\", type=\"cache\"}[$__range])) / clamp_min(sum(rate(gen_ai_tokens_total{job=\"efferent\", type=\"input\"}[$__range])), 1)", "legendFormat": "cache%", "refId": "A" } ]
    },
    {
      "type": "stat",
      "title": "Turns",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "targets": [ { "expr": "sum(increase(agent_turns_total{job=\"efferent\"}[$__range]))", "legendFormat": "turns", "refId": "A" } ]
    },

    { "type": "row", "title": "Reliability (RED)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },
    {
      "type": "timeseries",
      "title": "Turn rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [ { "expr": "sum(rate(agent_turns_total{job=\"efferent\"}[$__rate_interval]))", "legendFormat": "turns/s", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Error rate by kind (err/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } }, "color": { "mode": "palette-classic" } } },
      "targets": [ { "expr": "sum by (kind) (rate(agent_errors_total{job=\"efferent\"}[$__rate_interval]))", "legendFormat": "{{kind}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Turn latency (ms)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 0 } } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_turn_latency_ms_bucket{job=\"efferent\"}[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_turn_latency_ms_bucket{job=\"efferent\"}[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(agent_turn_latency_ms_bucket{job=\"efferent\"}[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    { "type": "row", "title": "LLM & cost", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 } },
    {
      "type": "timeseries",
      "title": "Token throughput by role/type (tok/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (role, type) (rate(gen_ai_tokens_total{job=\"efferent\", role=~\"$role\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{role}}/{{type}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Cost rate by role ($/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 5, "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (role) (rate(gen_ai_cost_usd_total{job=\"efferent\", role=~\"$role\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{role}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "LLM call rate by role/model (req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [ { "expr": "sum by (role, model) (rate(gen_ai_calls_total{job=\"efferent\", role=~\"$role\", model=~\"$model\"}[$__rate_interval]))", "legendFormat": "{{role}} {{model}}", "refId": "A" } ]
    },

    { "type": "row", "title": "Tools & approvals", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 } },
    {
      "type": "timeseries",
      "title": "Tool success rate by tool",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 0 } } },
      "targets": [ { "expr": "sum by (tool) (rate(agent_tool_calls_total{job=\"efferent\", ok=\"true\"}[$__rate_interval])) / clamp_min(sum by (tool) (rate(agent_tool_calls_total{job=\"efferent\"}[$__rate_interval])), 0.0001)", "legendFormat": "{{tool}}", "refId": "A" } ]
    },
    {
      "type": "timeseries",
      "title": "Tool call rate by tool/ok",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } } },
      "targets": [ { "expr": "sum by (tool, ok) (rate(agent_tool_calls_total{job=\"efferent\"}[$__rate_interval]))", "legendFormat": "{{tool}} ok={{ok}}", "refId": "A" } ]
    },
    {
      "type": "piechart",
      "title": "Auto-approval verdicts (range)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "legend": { "displayMode": "table", "placement": "right", "values": ["value"] } },
      "targets": [ { "expr": "sum by (verdict) (increase(approval_verdicts_total{job=\"efferent\"}[$__range]))", "legendFormat": "{{verdict}}", "refId": "A" } ]
    }
  ]
}

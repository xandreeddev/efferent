{
  "uid": "efferent-llm",
  "title": "efferent \u2014 llm",
  "tags": [
    "efferent",
    "llm"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "agent (service)",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(llm_requests_total, job)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "model",
        "label": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(llm_requests_total{job=~\"$service\"}, llm_model)",
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "refresh": 2,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "input tokens (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(llm_usage_input_tokens_total{job=~\"$service\",llm_model=~\"$model\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "output tokens (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(llm_usage_output_tokens_total{job=~\"$service\",llm_model=~\"$model\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "requests (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(llm_requests_total{job=~\"$service\",llm_model=~\"$model\"}[$__range]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "errors (range)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(llm_requests_total{job=~\"$service\",llm_model=~\"$model\",outcome=\"error\"}[$__range])) or vector(0)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "token throughput (per minute)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (llm_model) (rate(llm_usage_input_tokens_total{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "in \u2014 {{llm_model}}"
        },
        {
          "refId": "B",
          "expr": "sum by (llm_model) (rate(llm_usage_output_tokens_total{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "out \u2014 {{llm_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "request duration \u2014 p50 / p95 / p99",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, llm_model) (rate(llm_request_duration_milliseconds_bucket{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "p50 \u2014 {{llm_model}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, llm_model) (rate(llm_request_duration_milliseconds_bucket{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "p95 \u2014 {{llm_model}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, llm_model) (rate(llm_request_duration_milliseconds_bucket{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval])))",
          "legendFormat": "p99 \u2014 {{llm_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "requests per minute by outcome",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (llm_model, outcome) (rate(llm_requests_total{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval])) * 60",
          "legendFormat": "{{outcome}} \u2014 {{llm_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "mean request duration",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (llm_model) (rate(llm_request_duration_milliseconds_sum{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval])) / sum by (llm_model) (rate(llm_request_duration_milliseconds_count{job=~\"$service\",llm_model=~\"$model\"}[$__rate_interval]))",
          "legendFormat": "mean \u2014 {{llm_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "engine \u2014 trajectory quality",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "agent runs by outcome (completion rate)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (engine_outcome, engine_reason) (increase(engine_runs_total{job=~\"$service\"}[$__rate_interval]))",
          "legendFormat": "{{engine_outcome}} \u2014 {{engine_reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "tool calls by tool (failed dashed)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (engine_tool) (rate(engine_tool_calls_total{job=~\"$service\",engine_ok=\"true\"}[$__rate_interval])) * 60",
          "legendFormat": "{{engine_tool}}"
        },
        {
          "refId": "B",
          "expr": "sum by (engine_tool) (rate(engine_tool_calls_total{job=~\"$service\",engine_ok=\"false\"}[$__rate_interval])) * 60",
          "legendFormat": "FAILED {{engine_tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "self-corrections per minute",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 22
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (engine_kind) (rate(engine_corrections_total{job=~\"$service\"}[$__rate_interval])) * 60",
          "legendFormat": "{{engine_kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "type": "timeseries",
      "title": "judge verdicts per minute (sound / unsound / crash)",
      "description": "smith's judge gate \u2014 smith_judge_verdicts_total by verdict. A rising 'crash' means the gate is failing closed; rising 'unsound' means the coder is being caught.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 30
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (verdict) (rate(smith_judge_verdicts_total[5m])) * 60",
          "legendFormat": "{{verdict}}"
        }
      ]
    }
  ]
}

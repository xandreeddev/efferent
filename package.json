{
  "name": "efferent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun --hot packages/cli/src/main.ts",
    "start": "bun packages/cli/src/main.ts",
    "build": "bun build packages/cli/src/main.ts --target=bun --outfile packages/cli/dist/efferent.js",
    "eval": "bun packages/evals/src/run.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "effect": "^3.21.2"
  }
}

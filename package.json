{
  "name": "efferent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun --hot packages/cli/src/main.ts",
    "start": "bun packages/cli/src/main.ts",
    "build": "bun run scripts/build.ts",
    "eval": "bun packages/evals/src/run.ts",
    "generate-models": "bun packages/core/scripts/generateModelCatalog.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && bun scripts/banTryCatch.ts",
    "prepare": "bun scripts/installHooks.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "0.3.1",
    "@opentui/solid": "0.3.1",
    "effect": "^3.21.2",
    "solid-js": "^1.9.13",
    "web-tree-sitter": "0.25.10"
  }
}

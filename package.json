{
  "name": "efferent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*", "examples"],
  "scripts": {
    "dev": "bun --hot packages/cli/src/main.ts",
    "start": "bun packages/cli/src/main.ts",
    "start:fresh": "EFFERENT_HOME=$(mktemp -d) bun packages/cli/src/main.ts",
    "code": "bun packages/cli/src/main.ts code",
    "code:dev": "bun --hot packages/cli/src/main.ts code",
    "social": "bun packages/social/src/main.ts",
    "social:dev": "bun --hot packages/social/src/main.ts",
    "build": "bun run scripts/build.ts",
    "eval": "bun packages/evals/src/run.ts",
    "obs:up": "docker compose -f docker-compose.observability.yml up -d",
    "obs:down": "docker compose -f docker-compose.observability.yml down",
    "generate-models": "bun packages/sdk-core/scripts/generateModelCatalog.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && bun scripts/banTryCatch.ts",
    "prepare": "bun scripts/installHooks.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^24.13.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opentui/core": "0.3.1",
    "@opentui/solid": "0.3.1",
    "effect": "^3.21.4",
    "solid-js": "1.9.12",
    "web-tree-sitter": "0.25.10"
  }
}

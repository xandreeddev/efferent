#!/usr/bin/env bash
# Dev launcher for the MASTER assistant (`efferent`/`eff`). Runs the TS SOURCE
# directly so source edits are live with NO rebuild ("always fresh").
#
# Bun resolves Solid's `jsxImportSource` from the tsconfig at its CWD, so we run
# Bun WITH this repo as the cwd (otherwise the TUI's JSX falls back to React and
# breaks from other directories) and hand efferent the user's REAL directory via
# `EFFERENT_CWD` (honoured by resolveCwd as the default workspace when --cwd is
# absent). For the published bundle path instead: `bun run build` →
# packages/cli/dist/efferent.js.
set -euo pipefail
REPO="$(cd "$(dirname "$0")/.." && pwd)"
export EFFERENT_CWD="${EFFERENT_CWD:-$PWD}"
cd "$REPO"
exec bun "$REPO/packages/cli/src/main.ts" "$@"
